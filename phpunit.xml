<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
    <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="CACHE_DRIVER" value="array"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="LOG_CHANNEL" value="null"/> <env name="DB_CONNECTION" value="pgsql"/>
        <env name="DB_HOST" value="127.0.0.1"/>
        <env name="DB_PORT" value="5432"/>
        <env name="DB_DATABASE" value="testing"/>
        <env name="DB_USERNAME" value="postgres"/>
        <env name="DB_PASSWORD" value="password"/>
        <env name="WALLET_MATH_SCALE" value="0"/>
        <env name="WALLET_CACHE_DRIVER" value="array"/>
        <env name="WALLET_CACHE_TTL" value="86400"/> <env name="WALLET_LOCK_DRIVER" value="array"/>
        <env name="WALLET_LOCK_TTL" value="1"/> <env name="WALLET_TRANSACTION_TABLE_NAME" value="transactions"/> <env name="WALLET_TRANSFER_TABLE_NAME" value="transfers"/>
        <env name="WALLET_WALLET_TABLE_NAME" value="wallets"/>
        <env name="OPENAI_API_KEY" value="mock-openai-key"/>
        <env name="MISTRAL_API_KEY" value="mock-mistral-key"/>
        <env name="OPENROUTER_API_KEY" value="mock-openrouter-key"/>
