        <env name="PRISMALINK_MERCHANT_ID" value="mock-merchant-id"/>
        <env name="PRISMALINK_MERCHANT_KEY_ID" value="mock-key-id"/>
        <env name="PRISMALINK_SECRET_KEY" value="mock-secret-key"/>
        <env name="GOOGLE_CLIENT_ID" value="mock-google-client"/>
        <env name="GOOGLE_CLIENT_SECRET" value="mock-google-secret"/>
        <env name="AWS_ACCESS_KEY_ID" value="mock-aws-key"/>
        <env name="AWS_SECRET_ACCESS_KEY" value="mock-aws-secret"/>
        <env name="AWS_BUCKET" value="mock-bucket"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
