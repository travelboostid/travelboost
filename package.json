{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "dev:vite": "vite",
        "dev:queue": "php artisan queue:work",
        "dev:reverb": "php artisan reverb:start",
        "dev:scheduler": "php artisan schedule:work",
        "dev:serve": "php artisan serve",
        "format": "prettier --write resources/",
        "format:check": "prettier --check resources/",
        "lint": "eslint . --fix",
        "types": "tsc --noEmit",
        "dev:init": "pnpm install && composer install && pnpm dev:setenv",
        "dev:min": "concurrently \"pnpm dev:vite\" \"pnpm dev:serve\"",
        "dev:full": "concurrently \"pnpm dev:reverb\" \"pnpm dev:queue\" \"pnpm dev:scheduler\" \"pnpm dev:vite\" \"pnpm dev:serve\"",
        "i18n:extract": "formatjs extract \"resources/js/**/*.{ts,tsx,js,jsx}\" --ignore \"**/*.d.ts\" --ignore \"**/*.d.ts.map\" --out-file resources/js/lang/en.json --id-interpolation-pattern [sha512:contenthash:base64:6] --format simple",
        "i18n:diff": "node scripts/i18n-diff.mjs",
        "i18n:merge": "node scripts/i18n-merge.mjs",
        "dev:deploy": "node scripts/dev-deploy.mjs",
        "dev:deploy-main": "node scripts/dev-deploy-main.mjs",
        "dev:setenv": "node scripts/dev-setenv.mjs",
        "dev": "node scripts/dev.mjs",
        "prepare": "husky"
    },
