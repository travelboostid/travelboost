{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "WebBuildObjectReadWriteDelete",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetObject",
                "s3:DeleteObject",
                "s3:AbortMultipartUpload"
            ],
            "Resource": "arn:aws:s3:::tb-web-dev/*"
        },
        {
            "Sid": "WebBuildBucketList",
            "Effect": "Allow",
            "Action": ["s3:ListBucket"],
            "Resource": "arn:aws:s3:::tb-web-dev"
        }
    ]
}
