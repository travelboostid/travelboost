{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "DeveloperReadOnlyObjects",
            "Effect": "Allow",
            "Action": ["s3:GetObject"],
            "Resource": [
                "arn:aws:s3:::tb-media-dev/*",
                "arn:aws:s3:::tb-web-dev/*",
                "arn:aws:s3:::tb-backup-dev/*"
            ]
        },
        {
            "Sid": "DeveloperListBuckets",
            "Effect": "Allow",
            "Action": ["s3:ListBucket"],
            "Resource": [
                "arn:aws:s3:::tb-media-dev",
                "arn:aws:s3:::tb-web-dev",
                "arn:aws:s3:::tb-backup-dev"
            ]
        }
    ]
}
