{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "MediaObjectReadWriteDelete",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetObject",
                "s3:DeleteObject",
                "s3:AbortMultipartUpload"
            ],
            "Resource": "arn:aws:s3:::tb-media-dev/*"
        },
        {
            "Sid": "MediaBucketList",
            "Effect": "Allow",
            "Action": ["s3:ListBucket"],
            "Resource": "arn:aws:s3:::tb-media-dev",
            "Condition": {
                "StringLike": {
                    "s3:prefix": ["images/*", "media/*"]
                }
            }
        }
    ]
}
