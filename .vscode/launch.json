  "version": "0.2.0",
  "configurations": [
    {
      "name": "Listen for Xdebug (Web)",
      "type": "php",
      "request": "launch",
      "port": 9003
    },
    {
      "name": "Debug Artisan Command",
      "type": "php",
      "request": "launch",
      "program": "${workspaceFolder}/artisan",
      "args": ["queue:work"],
      "cwd": "${workspaceFolder}",
      "port": 9003,
      "env": {
        "XDEBUG_MODE": "debug"
      }
    }
  ]
}
