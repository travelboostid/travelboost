{
    // ========================
    // GLOBAL
    // ========================
    "editor.formatOnSave": true,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,

    // ========================
    // PRETTIER
    // ========================
    "prettier.enable": true,

    // ========================
    // ESLINT
    // ========================
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit"
    },

    "eslint.validate": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact"
    ],

    // ========================
    // JAVASCRIPT / TYPESCRIPT
    // ========================
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    "[javascriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    "[scss]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    // ========================
    // PHP / LARAVEL (PINT)
    // ========================
    "[php]": {
        "editor.defaultFormatter": "laravel.vscode-laravel"
    },

    // ========================
    // BLADE
    // ========================
    "[blade]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    // ========================
    // INERTIA / VITE
    // ========================
    "files.associations": {
        "*.jsx": "javascriptreact",
        "*.tsx": "typescriptreact"
    },

    // ========================
    // MISC
    // ========================
    "files.eol": "\n",

    "[csharp]": {
        "editor.defaultFormatter": "ms-dotnettools.csharp"
    },
    "intelephense.files.associations": ["*.php", "*.phtml"],
    "intelephense.codeLens.implementations.enable": true,
    "intelephense.codeLens.overrides.enable": true,
    "intelephense.codeLens.references.enable": true,
    "intelephense.codeLens.parent.enable": true,
    "intelephense.codeLens.usages.enable": true
}
