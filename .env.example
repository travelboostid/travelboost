APP_NAME=Travelboost
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_HOST=lvh.me
APP_PORT=8000
APP_SCHEME=http
APP_URL=${APP_SCHEME}://${APP_HOST}:${APP_PORT}

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
# Set to s3 on staging/production (requires S3_* credentials below)
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# We need to reserve this for real AWS services
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# We are using Neo S3 for now
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_BUCKET=
# Full bucket URL for public media links, e.g. https://nos.wjv-1.neo.id/tb-media-dev
S3_URL=
S3_ENDPOINT=
S3_USE_PATH_STYLE_ENDPOINT=true

WALLET_MATH_SCALE=
WALLET_CACHE_DRIVER=
WALLET_CACHE_TTL=
WALLET_LOCK_DRIVER=
WALLET_LOCK_TTL=
WALLET_TRANSACTION_TABLE_NAME=
WALLET_TRANSFER_TABLE_NAME=
WALLET_WALLET_TABLE_NAME=
WALLET_DEFAULT_WALLET_NAME="Main Wallet"
WALLET_DEFAULT_WALLET_SLUG=main_wallet

OPENAI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=

MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SANITIZED=true
MIDTRANS_3DS=true

PRISMALINK_MERCHANT_ID=
PRISMALINK_MERCHANT_KEY_ID=
PRISMALINK_SECRET_KEY=
PRISMALINK_IS_PRODUCTION=false
PRISMALINK_BACKEND_CALLBACK_URL=${APP_URL}/webhooks/prismalink/backend-callback
PRISMALINK_FRONTEND_CALLBACK_URL=${APP_URL}/webhooks/prismalink/frontend-callback
PRISMALINK_DEFAULT_VALIDITY_HOURS=24

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=local
REVERB_APP_KEY=local
REVERB_APP_SECRET=local
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

TELESCOPE_ENABLED=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL="${APP_URL}/auth/google/callback"

VITE_APP_NAME="${APP_NAME}"
VITE_APP_HOST=${APP_HOST}
VITE_APP_PORT=${APP_PORT}
VITE_APP_SCHEME=${APP_SCHEME}
VITE_APP_URL=${APP_URL}
VITE_APP_IP_HOST=${APP_IP_HOST}

VITE_BROADCAST_CONNECTION="${BROADCAST_CONNECTION}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

###########################

APP_IP_HOST=103.127.138.76
DEPLOY_BRANCH=dev
DEPLOY_SSH_USER=travelboost
DEPLOY_SSH_HOST=${APP_IP_HOST}
DEPLOY_TARGET_PATH=~/travelboost